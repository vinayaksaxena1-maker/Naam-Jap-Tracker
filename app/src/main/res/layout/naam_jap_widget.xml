<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="8dp">

    <!-- Container Card with modern rounded corners and rich dark spiritual theme -->
    <LinearLayout
        android:id="@+id/widget_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#221C1A"
        android:padding="16dp">

        <!-- Top Header: Logo/App Name and Streak Counter -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Naam Jap Tracker"
                android:textColor="#E65100"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="5 Days 🔥"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Main Content split into 2 Columns (Mantra Info and Increment Control) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left Column: Mantra info and Progress Bar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.3"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_mantra_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Om Namah Shivaya"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_progress_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Today: 108 / 1,000"
                    android:textColor="#B0A09B"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/widget_progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="10"
                    android:progressDrawable="@android:drawable/progress_horizontal" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <!-- Right Column: +1 Action Button -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:gravity="center"
                android:orientation="vertical">

                <Button
                    android:id="@+id/widget_btn_increment"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+1 JAP"
                    android:background="#E65100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
